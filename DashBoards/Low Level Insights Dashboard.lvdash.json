{
  "datasets": [
    {
      "name": "594b874b",
      "displayName": "Total Sensor Monitoring Records Summary",
      "queryLines": [
        "SELECT COUNT(*) AS total_sensor_readings\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring;"
      ]
    },
    {
      "name": "a265c55f",
      "displayName": "Unique Device Count Summary",
      "queryLines": [
        "SELECT COUNT(DISTINCT device_id) AS total_devices\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring;"
      ]
    },
    {
      "name": "7a6173f7",
      "displayName": "Critical Alerts Overview Report",
      "queryLines": [
        "SELECT COUNT(*) AS total_critical_alerts\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE sensor_status = 'CRITICAL';"
      ]
    },
    {
      "name": "194b9194",
      "displayName": "Average Sensor Readings Summary",
      "queryLines": [
        "SELECT AVG(reading_value) AS avg_sensor_reading\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring;"
      ]
    },
    {
      "name": "86fa6e96",
      "displayName": "Sensor Status Record Summary",
      "queryLines": [
        "SELECT\r\n",
        "sensor_status,\r\n",
        "COUNT(*) AS total_records\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "GROUP BY sensor_status;"
      ]
    },
    {
      "name": "ea1a08ba",
      "displayName": "Daily IoT Sensor Reading Counts Summary",
      "queryLines": [
        "SELECT\r\n",
        "DATE(event_timestamp) AS event_date,\r\n",
        "COUNT(*) AS total_readings\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "GROUP BY DATE(event_timestamp)\r\n",
        "ORDER BY event_date;"
      ]
    },
    {
      "name": "73887ac2",
      "displayName": "Network Provider Anomaly Overview",
      "queryLines": [
        "SELECT\r\n",
        "COALESCE(network_provider, 'UNKNOWN') AS network_provider,\r\n",
        "COUNT(*) AS anomaly_count\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE sensor_status != 'NORMAL'\r\n",
        "GROUP BY COALESCE(network_provider, 'UNKNOWN')\r\n",
        "ORDER BY anomaly_count DESC;"
      ]
    }
  ],
