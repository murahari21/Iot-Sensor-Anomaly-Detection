{
  "datasets": [
    {
      "name": "35597ca1",
      "displayName": "Device Event Counts by Date and Sensor Condition",
      "queryLines": [
        "SELECT\r\n",
        "DATE(event_timestamp) AS event_date,\r\n",
        "sensor_status,\r\n",
        "COUNT(*) AS total_events\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "GROUP BY DATE(event_timestamp), sensor_status\r\n",
        "ORDER BY event_date;"
      ]
    },
    {
      "name": "32cc4146",
      "displayName": "Regional IoT Sensor Anomaly Event Summary",
      "queryLines": [
        "SELECT\r\n",
        "region_name,\r\n",
        "severity_level,\r\n",
        "COUNT(*) AS total_events\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE region_name IS NOT NULL\r\n",
        "AND severity_level IS NOT NULL\r\n",
        "AND region_name <> 'UNKNOWN'\r\n",
        "AND severity_level <> 'UNKNOWN'\r\n",
        "GROUP BY region_name, severity_level\r\n",
        "ORDER BY total_events DESC;"
      ]
    },
    {
      "name": "868dc461",
      "displayName": "Device Downtime Analysis by Severity Levels",
      "queryLines": [
        "\r\n",
        "\r\n",
        "SELECT\r\n",
        "severity_level,\r\n",
        "downtime_minutes\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE downtime_minutes IS NOT NULL\r\n",
        "AND severity_level IS NOT NULL;"
      ]
    },
    {
      "name": "618eb384",
      "displayName": "Average Sensor Readings by Network Provider",
      "queryLines": [
        "SELECT\r\n",
        "network_provider,\r\n",
        "AVG(reading_value) AS avg_sensor_reading\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE network_provider IS NOT NULL\r\n",
        "GROUP BY network_provider\r\n",
        "ORDER BY avg_sensor_reading DESC;"
      ]
    }
  ],
