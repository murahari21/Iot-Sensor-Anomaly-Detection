{
  "datasets": [
    {
      "name": "8d4c1c40",
      "displayName": "Device Health Metrics and Anomaly Summary Report",
      "queryLines": [
        "SELECT\r\n",
        "DATE(event_timestamp) AS event_date,\r\n",
        "SUM(CASE \r\n",
        "        WHEN sensor_status <> 'NORMAL' THEN 1\r\n",
        "        ELSE 0\r\n",
        "    END) AS anomaly_count\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "GROUP BY DATE(event_timestamp)\r\n",
        "ORDER BY event_date;"
      ]
    },
    {
      "name": "ca0d9235",
      "displayName": "Top Device Risk Scores and Anomaly Summary Dataset",
      "queryLines": [
        "SELECT\r\n",
        "device_id,\r\n",
        "AVG(health_score) AS avg_health,\r\n",
        "SUM(error_count) AS total_errors,\r\n",
        "SUM(downtime_minutes) AS total_downtime,\r\n",
        "SUM(CASE \r\n",
        "        WHEN sensor_status <> 'NORMAL' THEN 1\r\n",
        "        ELSE 0\r\n",
        "    END) AS anomaly_count,\r\n",
        "\r\n",
        "(\r\n",
        "    SUM(error_count)*0.4 +\r\n",
        "    SUM(downtime_minutes)*0.3 +\r\n",
        "    SUM(CASE \r\n",
        "            WHEN sensor_status <> 'NORMAL' THEN 1\r\n",
        "            ELSE 0\r\n",
        "        END)*0.3\r\n",
        ") AS device_risk_score\r\n",
        "\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE health_score IS NOT NULL\r\n",
        "GROUP BY device_id\r\n",
        "ORDER BY device_risk_score DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "ce3906ca",
      "displayName": "Critical Sensor Anomaly Insights",
      "queryLines": [
        "SELECT\r\n",
        "device_id,\r\n",
        "sensor_identifier,\r\n",
        "reading_value,\r\n",
        "z_score,\r\n",
        "region_name\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "WHERE sensor_status = 'CRITICAL'\r\n",
        "ORDER BY z_score DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "4f7b4f49",
      "displayName": "Sensor Status Overview for Device Monitoring",
      "queryLines": [
        "SELECT\r\n",
        "sensor_status,\r\n",
        "COUNT(*) AS total_devices,\r\n",
        "ROUND(\r\n",
        "    COUNT(*) * 100.0 / SUM(COUNT(*)) OVER (),\r\n",
        "    2\r\n",
        ") AS percentage\r\n",
        "FROM iot_sensor_anomoly_detection.gold.fact_device_monitoring\r\n",
        "GROUP BY sensor_status\r\n",
        "ORDER BY total_devices DESC;"
      ]
    }
  ],
